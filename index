    const enfoqueKey = state.enfoque.toLowerCase();
    const disenoObj = DISENOS[enfoqueKey]?.find(d => d.id === state.diseno);
    const disenoLabel = disenoObj?.label || state.diseno;
    
    let variablesDisplay = state.variables.filter(v => v !== 'otro');
    if(state.variables.includes('otro') && state.variablesOtro.trim()) {
      const otrasVars = state.variablesOtro.split(',').map(v => v.trim()).filter(Boolean);
      variablesDisplay = variablesDisplay.concat(otrasVars);
    }
    
    [["Area",efectiveArea()],["Poblacion",efectivePoblacion()],["Problema",efectiveProblema()],
     ["Variables",variablesDisplay.join(", ")],["Enfoque",state.enfoque],["Nivel",nivelLabel],["Diseño",disenoLabel]].forEach(([k,v])=>{
      h+=`<p><span>${k}:</span> ${v}</p>`;
    });
    h+=`</div></div>`;

    // PRÓXIMOS PASOS
    h+=`<div class="next-steps">
      <div class="next-steps-title">🎯 Próximos pasos para tu proyecto</div>
      <ul>
        <li><strong>Justificación:</strong> Explica por qué es importante investigar este tema (relevancia teórica, práctica y social)</li>
        <li><strong>Marco teórico:</strong> Busca 5-10 artículos recientes (últimos 5 años) sobre tu tema en Google Académico, Redalyc o SciELO</li>
        <li><strong>Metodología:</strong> Define tu muestra, instrumentos de medición y procedimiento de recolección</li>
        <li><strong>Cronograma:</strong> Establece tiempos realistas para cada fase de tu investigación</li>
      </ul>
    </div>`;
    
    el.innerHTML=h;
  }
}

function updateNav(){
  document.getElementById("btn-back").disabled=state.step===0;
  const nb=document.getElementById("btn-next");
  nb.disabled=!canNext();
  nb.style.display=state.step===5?"none":"block";
}

function render(){
  renderStepsBar();
  renderContent();
  updateNav();
}

function nextStep(){if(canNext()&&state.step<5){state.step++;render();saveState();}}
function prevStep(){if(state.step>0){state.step--;render();saveState();}}

function selectArea(v){state.area=v;state.areaOtro="";state.poblacion="";state.poblacionOtro="";state.problema="";state.problemaOtro="";state.variables=[];updateNav();renderContent();saveState();}
function selectPoblacion(v){state.poblacion=v;state.poblacionOtro="";updateNav();renderContent();saveState();}
function selectProblema(v){state.problema=v;state.problemaOtro="";state.variables=[];state.variablesOtro="";updateNav();renderContent();saveState();}
function selectEnfoque(v){state.enfoque=v;state.nivel="";state.diseno="";updateNav();renderContent();saveState();}
function selectNivel(v){state.nivel=v;updateNav();renderContent();saveState();}
function selectDiseno(v){state.diseno=v;updateNav();renderContent();saveState();}

function toggleVar(v){
  const i=state.variables.indexOf(v);
  if(i>-1) state.variables.splice(i,1); else state.variables.push(v);
  updateNav();renderContent();saveState();
}
function setVarsFromText(val){
  const vars = val.split(",").map(v=>v.trim()).filter(Boolean);
  state.variables = vars;
  state.variablesOtro = val;
  updateNav();
}
function toggleEdit(){state.editMode=!state.editMode;renderContent();}

function nuevoProyecto(){
  if(confirm('¿Estás seguro de que quieres empezar un nuevo proyecto? Se perderá toda la información actual.')){
    // Limpiar localStorage
    localStorage.removeItem('investigacion_state');
    
    // Reiniciar estado
    state = {
      step:0,
      area:"",
      areaOtro:"",
      poblacion:"",
      poblacionOtro:"",
      problema:"",
      problemaOtro:"",
      variables:[],
      variablesOtro:"",
      enfoque:"",
      nivel:"",
      diseno:"",
      experiencia:"",
      viabilidad:"",
      contexto:"",
      motivacion:"",
      result:null,
      loading:false,
      editMode:false,
      edited:{tema:"",pregunta:"",objetivo:"",hipotesis:""}
    };
    
    // Volver al inicio
    render();
  }
}

async function generate(){
  state.loading=true;state.result=null;renderContent();
  
  let variablesList = state.variables.filter(v => v !== 'otro');
  if(state.variables.includes('otro') && state.variablesOtro.trim()) {
    const otrasVars = state.variablesOtro.split(',').map(v => v.trim()).filter(Boolean);
    variablesList = variablesList.concat(otrasVars);
  }
  
  const nv = variablesList.length;
  const nivelLabel = NIVELES.find(n => n.id === state.nivel)?.label || state.nivel;
  const enfoqueKey = state.enfoque.toLowerCase();
  const disenoObj = DISENOS[enfoqueKey]?.find(d => d.id === state.diseno);
  const disenoLabel = disenoObj?.label || state.diseno;
  
  const prompt=`Eres un experto en metodologia de la investigacion en psicologia (Hernandez, Fernandez y Baptista, 2014; Hernandez y Mendoza, 2018).
Un estudiante de 9no ciclo de Psicologia respondio:
- Area: ${efectiveArea()}
- Poblacion: ${efectivePoblacion()}
- Problema/fenomeno: ${efectiveProblema()}
- Variables seleccionadas (${nv}): ${variablesList.join(", ")}
- Enfoque metodologico: ${state.enfoque}
- Nivel de investigacion: ${nivelLabel}
- Diseño de investigacion: ${disenoLabel}
- Experiencia previa: ${state.experiencia}
- Viabilidad de acceso: ${state.viabilidad}
- Contexto: ${state.contexto||"No especificado"}
- Motivacion: ${state.motivacion||"No especificada"}

Genera:
1. TEMA DE INVESTIGACION delimitado (max 15 palabras), claro, coherente con el nivel y diseño, viable para pregrado.
2. PREGUNTA DE INVESTIGACION principal (interrogativa, coherente con enfoque, nivel, diseño y variables).
3. OBJETIVO GENERAL (verbo en infinitivo coherente con la pregunta, nivel y diseño; medible y alcanzable).
4. ${state.enfoque === "Cuantitativo" ? "HIPOTESIS DE INVESTIGACION: Enunciado afirmativo y específico que predice la relación entre las variables (ej: 'Existe una relación positiva entre X e Y en...')" : state.enfoque === "Cualitativo" ? "HIPOTESIS DE TRABAJO: Supuesto tentativo y flexible sobre el fenómeno (ej: 'Las experiencias de X influyen en...'). Si el nivel es exploratorio puro, usa: 'Se busca comprender...'" : "HIPOTESIS: Según tu diseño mixto, formula una hipótesis predictiva o tentativa"}

IMPORTANTE: Debes generar las 4 elementos. La hipótesis es OBLIGATORIA.

Responde SOLO en JSON exacto sin texto adicional ni markdown:
{"tema":"...","pregunta":"...","objetivo":"...","hipotesis":"..."}`;

  try{
    // Llamar a la API de Claude (requiere backend configurado)
    const res=await fetch("/api/chat",{
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:1500,messages:[{role:"user",content:prompt}]})
    });
    
    if (!res.ok) {
      throw new Error(`Error ${res.status}: La API no está disponible. Verifica que el servidor backend esté corriendo.`);
    }
    
    const data=await res.json();
    const text=data.content?.map(b=>b.text||"").join("")||"";
    const parsed=JSON.parse(text.replace(/```json|```/g,"").trim());
    
    // Asegurar que hipótesis existe
    if(!parsed.hipotesis) {
      if(state.enfoque === "Cuantitativo") {
        parsed.hipotesis = "Existe una relación significativa entre las variables seleccionadas.";
      } else if(state.enfoque === "Cualitativo") {
        parsed.hipotesis = "Se espera identificar patrones emergentes relacionados con el fenómeno de estudio.";
      } else {
        parsed.hipotesis = "Se plantean supuestos iniciales que guiarán la investigación mixta.";
      }
    }
    
    state.result=parsed;
    state.edited={...parsed};
    saveState();
  }catch(e){
    console.error("Error completo:", e);
    
    // Generar propuesta de ejemplo si falla la API
    const ejemploTema = `${efectiveProblema()} en ${efectivePoblacion()} - ${efectiveArea()}`;
    const ejemploPregunta = state.enfoque === "Cuantitativo" 
      ? `¿Cuál es la relación entre ${variablesList[0] || 'las variables'} y ${variablesList[1] || 'el fenómeno'} en ${efectivePoblacion()}?`
      : `¿Cómo se manifiesta ${efectiveProblema()} en las experiencias de ${efectivePoblacion()}?`;
    const ejemploObjetivo = state.enfoque === "Cuantitativo"
      ? `Determinar la relación entre ${variablesList.slice(0,2).join(' y ')} en ${efectivePoblacion()}.`
      : `Comprender el fenómeno de ${efectiveProblema()} en ${efectivePoblacion()}.`;
    const ejemploHipotesis = state.enfoque === "Cuantitativo"
      ? `Existe una relación positiva entre ${variablesList[0] || 'las variables seleccionadas'} y ${variablesList[1] || 'el fenómeno de estudio'} en ${efectivePoblacion()}.`
      : `Las experiencias de ${efectivePoblacion()} en relación a ${efectiveProblema()} están influenciadas por factores contextuales y personales.`;
    
    state.result={
      tema: ejemploTema.substring(0, 100),
      pregunta: ejemploPregunta,
      objetivo: ejemploObjetivo,
      hipotesis: ejemploHipotesis,
      error: `⚠️ API no disponible. Se generó un ejemplo basado en tus selecciones. IMPORTANTE: Debes configurar el backend (/api/chat) para usar la generación con IA. Mientras tanto, edita manualmente este ejemplo.`
    };
    state.edited={...state.result};
    delete state.edited.error;
    saveState();
  }
  state.loading=false;
  renderContent();
}

// FUNCIÓN DE DESCARGA EN DOCX
