  const nivelLabel = NIVELES.find(n => n.id === state.nivel)?.label || state.nivel;
  const enfoqueKey = state.enfoque.toLowerCase();
  const disenoObj = DISENOS[enfoqueKey]?.find(d => d.id === state.diseno);
  const disenoLabel = disenoObj?.label || state.diseno;
  
  let variablesDisplay = state.variables.filter(v => v !== 'otro');
  if(state.variables.includes('otro') && state.variablesOtro.trim()) {
    const otrasVars = state.variablesOtro.split(',').map(v => v.trim()).filter(Boolean);
    variablesDisplay = variablesDisplay.concat(otrasVars);
  }

  const content = `
PROPUESTA DE PROYECTO DE INVESTIGACIÓN

TEMA DE INVESTIGACIÓN
${state.edited.tema}

PREGUNTA DE INVESTIGACIÓN
${state.edited.pregunta}

OBJETIVO GENERAL
${state.edited.objetivo}

${state.enfoque === "Cuantitativo" ? "HIPÓTESIS DE INVESTIGACIÓN" : state.enfoque === "Cualitativo" ? "HIPÓTESIS DE TRABAJO" : "HIPÓTESIS"}
${state.edited.hipotesis}

RESUMEN METODOLÓGICO
Área: ${efectiveArea()}
Población: ${efectivePoblacion()}
Problema/Fenómeno: ${efectiveProblema()}
Variables: ${variablesDisplay.join(", ")}
Enfoque metodológico: ${state.enfoque}
Nivel de investigación: ${nivelLabel}
Diseño de investigación: ${disenoLabel}

---
Generado con Asistente de Investigación
Creado por: Alan A. Vega Jacome
  `.trim();

  const blob = new Blob([content], { type: 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'propuesta_investigacion.txt';
  a.click();
  URL.revokeObjectURL(url);
}

render();
</script>
