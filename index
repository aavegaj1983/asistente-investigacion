<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Asistente para la creación de proyectos de investigación</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f4f0;min-height:100vh;display:flex;justify-content:center;padding:24px 16px}
.card{background:#fff;border-radius:16px;border:0.5px solid #e0e0e0;padding:28px 24px;width:100%;max-width:620px;height:fit-content}
h2{font-size:18px;font-weight:500;margin-bottom:4px;color:#111}
.steps{display:flex;align-items:center;gap:4px;margin-bottom:6px}
.step-circle{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;cursor:default;transition:all .2s}
.step-circle.done{background:#534AB7;color:#fff;cursor:pointer}
.step-circle.active{background:#EEEDFE;color:#534AB7;border:2px solid #534AB7}
.step-circle.pending{background:#f0f0f0;color:#aaa}
.step-line{height:1px;width:16px}
.step-line.done{background:#534AB7}
.step-line.pending{background:#e0e0e0}
.step-label{font-size:12px;color:#888;margin-bottom:20px}
.section-label{font-size:13px;color:#888;font-weight:500;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.tooltip{position:relative;display:inline-flex;cursor:help}
.tooltip-icon{width:16px;height:16px;background:#534AB7;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:bold}
.tooltip-text{visibility:hidden;width:240px;background:#333;color:#fff;text-align:left;border-radius:6px;padding:8px 10px;position:absolute;z-index:1;bottom:125%;left:50%;margin-left:-120px;opacity:0;transition:opacity .3s;font-size:12px;line-height:1.4;font-weight:normal}
.tooltip-text::after{content:"";position:absolute;top:100%;left:50%;margin-left:-5px;border-width:5px;border-style:solid;border-color:#333 transparent transparent transparent}
.tooltip:hover .tooltip-text{visibility:visible;opacity:1}
.options{display:flex;flex-direction:column;gap:8px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.badge{padding:10px 16px;border-radius:8px;cursor:pointer;text-align:left;border:0.5px solid #ccc;background:transparent;font-size:14px;font-weight:400;width:100%;transition:all .15s;position:relative}
.badge:hover{border-color:#999}
.badge.active{border:2px solid #534AB7;background:#EEEDFE;color:#3C3489;font-weight:500}
.badge-title{font-weight:500;margin-bottom:2px}
.badge-desc{font-size:12px;color:#777;margin-top:2px}
.badge-hint{font-size:11px;color:#6b7280;margin-top:4px;font-style:italic}
.badge-hint.recommended{color:#0F6E56;font-weight:500}
.chip{padding:6px 12px;border-radius:20px;cursor:pointer;font-size:13px;border:0.5px solid #ccc;background:transparent;transition:all .15s}
.chip:hover{border-color:#0F6E56}
.chip.active{border:2px solid #0F6E56;background:#E1F5EE;color:#0F6E56;font-weight:500}
.chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px}
.hint{background:#EEEDFE;border-radius:8px;padding:8px 12px;font-size:13px;color:#3C3489;margin-top:4px}
.hint.warning{background:#FEF3E8;color:#B45309}
.hint.success{background:#E1F5EE;color:#0F6E56}
input[type=text],textarea{width:100%;font-size:14px;padding:8px 10px;border-radius:8px;border:0.5px solid #ccc;font-family:inherit;margin-top:4px}
input[type=text]:focus,textarea:focus{outline:none;border-color:#534AB7}
textarea{min-height:60px;resize:vertical}
.otro-input{border:1px solid #534AB7 !important;margin-top:6px}
.nav{display:flex;justify-content:space-between;margin-top:28px;padding-top:16px;border-top:0.5px solid #e5e5e5}
.btn{padding:10px 20px;border-radius:8px;font-size:14px;cursor:pointer;font-family:inherit;border:none;transition:all .2s}
.btn-back{border:0.5px solid #ccc;background:transparent;color:#333}
.btn-back:disabled{opacity:0.4;cursor:not-allowed}
.btn-next{background:#534AB7;color:#fff;font-weight:500;padding:10px 24px}
.btn-next:disabled{background:#ccc;cursor:not-allowed}
.content{min-height:280px}
.gap20{display:flex;flex-direction:column;gap:20px}
.result-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:8px}
.result-header p{font-size:13px;color:#888}
.result-actions{display:flex;gap:8px;flex-wrap:wrap}
.btn-sm{padding:6px 14px;border-radius:6px;font-size:13px;cursor:pointer;font-family:inherit;border:0.5px solid #ccc;background:transparent;transition:all .2s}
.btn-sm:hover{background:#f5f5f5}
.btn-edit{border-color:#ccc}
.btn-regen{border-color:#534AB7;color:#534AB7}
.btn-download{border-color:#0F6E56;color:#0F6E56}
.result-block{border-radius:10px;padding:14px 16px;margin-bottom:16px}
.result-block-label{font-size:11px;font-weight:500;margin-bottom:6px;text-transform:uppercase;letter-spacing:1px}
.result-block p{font-size:15px;line-height:1.6;color:#222}
.result-block textarea{font-size:14px;padding:8px;border-radius:6px;min-height:60px;width:100%;border:0.5px solid #ccc}
.summary{margin-top:4px;padding:12px 16px;background:#f9f9f7;border-radius:8px;border:0.5px solid #e0dfd5}
.summary p.title{font-size:12px;color:#888;margin-bottom:6px;font-weight:500}
.summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px}
.summary-grid p{font-size:12px;color:#555}
.summary-grid span{color:#888}
.loading{text-align:center;padding:40px 0}
.loading .icon{font-size:32px;margin-bottom:12px}
.loading p{color:#888;font-size:14px}
.generate-box{text-align:center;padding:32px 0}
.generate-box p{margin-bottom:20px;font-size:15px;color:#555}
.btn-generate{padding:12px 32px;border-radius:8px;background:#534AB7;color:#fff;border:none;font-size:15px;font-weight:500;cursor:pointer;font-family:inherit}
.btn-generate:hover{background:#3C3489}
.error{color:red;font-size:14px}
.footer{text-align:center;margin-top:24px;padding-top:16px;border-top:0.5px solid #e5e5e5;font-size:12px;color:#888}
.footer strong{color:#534AB7}
.next-steps{margin-top:16px;padding:16px;background:#f0fdf4;border-radius:8px;border:1px solid #86efac}
.next-steps-title{font-size:14px;font-weight:600;color:#166534;margin-bottom:12px;display:flex;align-items:center;gap:6px}
.next-steps ul{list-style:none;padding:0}
.next-steps li{padding:8px 0;font-size:13px;color:#166534;display:flex;align-items:start;gap:8px}
.next-steps li::before{content:"✓";color:#22c55e;font-weight:bold;font-size:16px}
.auto-save{position:fixed;bottom:16px;right:16px;background:#fff;border:1px solid #e5e5e5;padding:8px 12px;border-radius:20px;font-size:11px;color:#888;box-shadow:0 2px 8px rgba(0,0,0,0.1);display:none}
.auto-save.show{display:block;animation:fadeIn 0.3s}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

/* RESPONSIVE MOBILE */
@media (max-width: 768px) {
  body{padding:16px 12px}
  .card{padding:20px 16px;max-width:100%;border-radius:12px}
  h2{font-size:16px;line-height:1.3}
  .steps{gap:3px}
  .step-circle{width:24px;height:24px;font-size:11px}
  .step-line{width:12px}
  .step-label{font-size:11px;margin-bottom:16px}
  .section-label{font-size:12px}
  .grid2,.grid3{grid-template-columns:1fr;gap:8px}
  .badge{padding:12px 14px;font-size:13px}
  .badge-title{font-size:13px}
  .badge-desc{font-size:11px}
  .badge-hint{font-size:10px}
  .chip{padding:8px 12px;font-size:12px}
  .hint{padding:10px 12px;font-size:12px}
  .tooltip-text{width:200px;margin-left:-100px;font-size:11px;padding:6px 8px}
  .nav{flex-direction:column;gap:10px;margin-top:20px}
  .btn{width:100%;padding:12px 20px;font-size:14px}
  .btn-next{order:-1}
  .result-header{flex-direction:column;align-items:flex-start;gap:12px}
  .result-actions{width:100%;flex-direction:column}
  .btn-sm{width:100%;padding:10px 14px;text-align:center}
  .result-block{padding:12px 14px}
  .result-block p{font-size:14px}
  .result-block textarea{font-size:13px}
  .summary-grid{grid-template-columns:1fr;gap:8px}
  .next-steps{padding:14px}
  .next-steps-title{font-size:13px}
  .next-steps li{font-size:12px;padding:6px 0}
  .auto-save{bottom:12px;right:12px;font-size:10px;padding:6px 10px}
  .generate-box{padding:24px 0}
  .generate-box p{font-size:14px}
  .btn-generate{padding:12px 24px;font-size:14px;width:100%}
  .footer{font-size:11px;margin-top:20px}
}

@media (max-width: 480px) {
  .card{padding:16px 12px}
  h2{font-size:15px}
  .steps{overflow-x:auto;padding-bottom:8px}
  .badge{font-size:12px;padding:10px 12px}
  .chip{font-size:11px;padding:6px 10px}
  .result-block p{font-size:13px}
}
</style>
</head>
