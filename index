// GUARDAR ESTADO AUTOMÁTICAMENTE
function saveState() {
  try {
    localStorage.setItem('investigacion_state', JSON.stringify(state));
    showAutoSave();
  } catch(e) {}
}

function showAutoSave() {
  const el = document.getElementById('auto-save');
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 2000);
}

function efectiveArea(){return state.area==="otro"?state.areaOtro:AREAS.find(a=>a.id===state.area)?.label||"";}
function efectivePoblacion(){return state.poblacion==="otro"?state.poblacionOtro:state.poblacion;}
function efectiveProblema(){return state.problema==="otro"?state.problemaOtro:state.problema;}

function canNext(){
  const s=state.step;
  if(s===0){
    if(state.area==="otro") return state.areaOtro.trim()!=="";
    return state.area!=="";
  }
  if(s===1){
    if(state.poblacion==="otro") return state.poblacionOtro.trim()!=="";
    return state.poblacion!=="";
  }
  if(s===2){
    // Si problema es "otro", necesita problema especificado Y variables
    if(state.problema==="otro") {
      return state.problemaOtro.trim()!=="" && state.variablesOtro.trim()!=="";
    }
    // Si seleccionó "otro" en variables, necesita variables especificadas
    if(state.variables.includes('otro')) {
      return state.variables.length>0 && state.variablesOtro.trim()!=="";
    }
    // Caso normal: problema seleccionado y al menos una variable
    return state.problema!=="" && state.variables.length>0;
  }
  if(s===3) return state.enfoque!=="" && state.nivel!=="" && state.diseno!=="";
  if(s===4) return state.experiencia!=="" && state.viabilidad!=="";
  return true;
}

function badge(label, active, click){
  return `<button class="badge ${active?'active':''}" onclick="${click}">${label}</button>`;
}

function badgeWithDesc(title, desc, hint, active, click, recommended=false){
  const hintClass = recommended ? 'recommended' : '';
  return `<button class="badge ${active?'active':''}" onclick="${click}">
    <div class="badge-title">${title}</div>
    <div class="badge-desc">${desc}</div>
    ${hint ? `<div class="badge-hint ${hintClass}">${hint}</div>` : ''}
  </button>`;
}

function sectionLabel(t, tooltip=""){
  if(tooltip) {
    return `<p class="section-label">${t} <span class="tooltip"><span class="tooltip-icon">?</span><span class="tooltip-text">${tooltip}</span></span></p>`;
  }
  return `<p class="section-label">${t}</p>`;
}

function renderStepsBar(){
  let h="";
  STEPS.forEach((name,i)=>{
    const done=i<state.step;
    const active=i===state.step;
    const pending=i>state.step;
    let cls=done?"done":active?"active":"pending";
    h+=`<div class="step-circle ${cls}" onclick="${done?`state.step=${i};render()`:''}">${done?'✓':i+1}</div>`;
    if(i<STEPS.length-1){
      h+=`<div class="step-line ${done?'done':'pending'}"></div>`;
    }
  });
  document.getElementById("steps-bar").innerHTML=h;
  document.getElementById("step-label").textContent=`Paso ${state.step+1} de 6: ${STEPS[state.step]}`;
}

// SUGERENCIAS AUTOMÁTICAS
function getAutoSuggestion() {
  if(!state.enfoque || !state.variables.length) return "";
  
  const nv = state.variables.filter(v => v !== 'otro').length;
  const enfoque = state.enfoque.toLowerCase();
  
  // Validación: Cualitativo con muchas variables
  if(enfoque === "cualitativo" && nv >= 4) {
    return `<div class="hint warning">⚠️ Para enfoque cualitativo, usualmente se trabaja con menos variables (1-2) y se profundiza más en cada una. ¿Estás seguro de necesitar ${nv} variables?</div>`;
  }
  
  // Sugerencia automática según variables
  if(nv === 1) {
    return `<div class="hint success">💡 Sugerencia: Con 1 variable, nivel <strong>descriptivo</strong> es ideal. Diseño recomendado: <strong>${enfoque === 'cuantitativo' ? 'no experimental transversal' : 'estudio de caso'}</strong>.</div>`;
  }
  if(nv === 2) {
    return `<div class="hint success">💡 Sugerencia: Con 2 variables, nivel <strong>correlacional</strong> es apropiado. Diseño recomendado: <strong>${enfoque === 'cuantitativo' ? 'no experimental transversal' : 'estudio de caso múltiple'}</strong>.</div>`;
  }
  if(nv >= 3 && enfoque === 'cuantitativo') {
    return `<div class="hint success">💡 Sugerencia: Con ${nv} variables, nivel <strong>correlacional o explicativo</strong>. Diseño recomendado: <strong>no experimental transversal</strong> (o experimental si puedes manipular).</div>`;
  }
  
  return "";
}

